# Copy this file to .env and fill in your Anthropic API key.
# Get one at https://console.anthropic.com — free tier is plenty.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: which model to use. claude-3-5-haiku is the fastest and cheapest;
# claude-sonnet-4-5 gives more in-character responses for the LLM fallback.
WRAITH_MODEL=claude-3-5-haiku-latest
